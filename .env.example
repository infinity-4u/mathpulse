# Copy to .env.local — NEVER commit .env.local to git

# Supabase — MUST be Sydney region (ap-southeast-2)
# CONTRACT.md §2 and compliance.md: all user data in Australia
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>   # server-side only, never expose to client

# Supabase region — used by the AU-region tripwire test
SUPABASE_REGION=ap-southeast-2

# Vercel region — set syd1 in Vercel project settings too
# VERCEL_REGION=syd1

# Transactional email — must be AU/EU hosted (compliance.md APP 8)
EMAIL_FROM=noreply@yourdomain.com.au
# EMAIL_PROVIDER_API_KEY=<key>
