      "id": "AC9M7M06-001",
      "type": "multiple_choice",
      "stem": "A scale model uses a scale of 1:20. If the model is 15 cm long, how long is the real object?",
      "options": [
        "15 cm",
        "30 cm",
        "300 cm",
        "150 cm"
      ],
      "answer": {
        "type": "multiple_choice",
        "correct": "300 cm"
      },
      "difficulty": 1,
      "hints": {
        "default": [
          "Scale 1:20 means 1 cm on model = 20 cm in real life.",
          "Real length = 15 × 20.",
          "15 × 20 = 300 cm."
        ]
      },
      "worked_solution": "Real length = 15 × 20 = 300 cm."
    },
    {
