    {
      "id": "AC9M7M06-003",
      "type": "numeric",
      "stem": "Mix ratio of orange juice to water is 1:4. To make 20 L of drink, how many litres of orange juice are needed?",
      "answer": {
        "type": "numeric",
        "value": 4,
        "tolerance": 0
      },
      "difficulty": 2,
      "hints": {
        "default": [
