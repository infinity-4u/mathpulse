      "type": "numeric",
      "stem": "Calculate \\(2^3\\).",
      "answer": {
        "type": "numeric",
        "value": 8,
        "tolerance": 0
      },
      "difficulty": 1,
      "hints": {
        "default": [
          "\\(2^3\\) means 2 multiplied by itself 3 times.",
          "Write it out: \\(2 \\times 2 \\times 2\\).",
          "\\(2 \\times 2 = 4\\), then \\(4 \\times 2 = ?\\)."
        ]
      },
      "worked_solution": "\\(2^3 = 2 \\times 2 \\times 2 = 4 \\times 2 = 8\\)."
    },
