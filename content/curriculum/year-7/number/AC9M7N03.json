      "type": "multiple_choice",
      "stem": "Which fraction is equivalent to \\(\\frac{1}{2}\\)?",
      "options": [
        "\\(\\frac{2}{5}\\)",
        "\\(\\frac{3}{6}\\)",
        "\\(\\frac{4}{9}\\)",
        "\\(\\frac{5}{9}\\)"
      ],
      "answer": {
        "type": "multiple_choice",
        "correct": "\\(\\frac{3}{6}\\)"
      },
      "difficulty": 1,
      "hints": {
        "default": [
          "Multiply numerator and denominator by the same number.",
          "\\(\\frac{1}{2}=\\frac{1\\times3}{2\\times3}=\\frac{?}{6}\\).",
          "\\(\\frac{1\\times3}{2\\times3}=\\frac{3}{6}\\)."
        ]
      },
      "worked_solution": "\\(\\frac{1}{2}=\\frac{3}{6}\\) because \\(1\\times3=3\\) and \\(2\\times3=6\\)."
    },
