      "type": "numeric",
      "stem": "Find the mean of the dataset: 3, 5, 7, 9, 6.",
      "answer": {
        "type": "numeric",
        "value": 6,
        "tolerance": 0
      },
      "difficulty": 1,
      "hints": {
        "default": [
          "Mean = sum of all values ÷ number of values.",
          "Sum = 3+5+7+9+6 = 30. Count = 5.",
          "30 ÷ 5 = ?"
        ]
      },
      "worked_solution": "Mean = (3+5+7+9+6) ÷ 5 = 30 ÷ 5 = 6."
    },
